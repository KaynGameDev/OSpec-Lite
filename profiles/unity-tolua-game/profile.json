{
  "version": 1,
  "id": "unity-tolua-game",
  "displayName": "Unity + ToLua Game",
  "description": "Repo-local reading workflow and authoring pack for Unity + ToLua game repositories.",
  "documentLanguage": "zh-CN",
  "authoringPackRoot": "docs/agents/authoring",
  "requiredRepoPaths": [
    "Script/MJGame.lua"
  ],
  "outputs": [
    "AGENTS.md",
    "CLAUDE.md",
    "docs/project/overview.md",
    "docs/project/architecture.md",
    "docs/project/repo-map.md",
    "docs/project/entrypoints.md",
    "docs/project/glossary.md",
    "docs/project/coding-rules.md",
    "docs/agents/quickstart.md",
    "docs/agents/change-playbook.md",
    "docs/agents/authoring/doc-contract.md",
    "docs/agents/authoring/project-brief.md",
    "docs/agents/authoring/repo-reading-checklist.md",
    "docs/agents/authoring/evidence-map.md",
    "docs/agents/authoring/fill-project-docs.md",
    "docs/agents/authoring/doc-task-checklist.json"
  ],
  "assets": [
    { "source": "templates/AGENTS.md", "target": "AGENTS.md", "mode": "managed-codex-section" },
    { "source": "templates/CLAUDE.md", "target": "CLAUDE.md", "mode": "managed-claude-section" },
    { "source": "templates/docs/project/overview.md", "target": "docs/project/overview.md" },
    { "source": "templates/docs/project/architecture.md", "target": "docs/project/architecture.md" },
    { "source": "templates/docs/project/repo-map.md", "target": "docs/project/repo-map.md" },
    { "source": "templates/docs/project/entrypoints.md", "target": "docs/project/entrypoints.md" },
    { "source": "templates/docs/project/glossary.md", "target": "docs/project/glossary.md" },
    { "source": "templates/docs/project/coding-rules.md", "target": "docs/project/coding-rules.md" },
    { "source": "templates/docs/agents/quickstart.md", "target": "docs/agents/quickstart.md" },
    { "source": "templates/docs/agents/change-playbook.md", "target": "docs/agents/change-playbook.md" },
    { "source": "authoring-pack/doc-contract.md", "target": "docs/agents/authoring/doc-contract.md" },
    { "source": "authoring-pack/project-brief.md", "target": "docs/agents/authoring/project-brief.md" },
    { "source": "authoring-pack/repo-reading-checklist.md", "target": "docs/agents/authoring/repo-reading-checklist.md" },
    { "source": "authoring-pack/evidence-map.md", "target": "docs/agents/authoring/evidence-map.md" },
    { "source": "authoring-pack/fill-project-docs.md", "target": "docs/agents/authoring/fill-project-docs.md" },
    { "source": "authoring-pack/doc-task-checklist.json", "target": "docs/agents/authoring/doc-task-checklist.json" }
  ]
}
